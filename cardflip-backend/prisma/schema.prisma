generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  Unverified
  Pending
  Verified
  Rejected
}

enum TradeStatus {
  Pending
  Processing
  Approved
  Rejected
  Paid
}

enum TransactionType {
  credit
  debit
  fee
}

enum PayoutStatus {
  Pending
  Processing
  Completed
  Failed
}

enum TicketStatus {
  Open
  InProgress
  Resolved
  Closed
}

enum UserRole {
  user
  admin
  super_admin
}

model User {
  id             String    @id @default(cuid())
  phone          String    @unique
  email          String?   @unique
  password_hash  String
  pin_hash       String
  full_name      String?
  profile_photo  String?
  role           UserRole  @default(user)
  referral_code  String    @unique
  referred_by    String?
  kyc_status     KycStatus @default(Unverified)
  is_frozen      Boolean   @default(false)
  is_active      Boolean   @default(true)
  fcm_token      String?
  last_login_at  DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  referrer           User?           @relation("Referrals", fields: [referred_by], references: [id])
  referrals          User[]          @relation("Referrals")
  kyc                KYC?
  wallet             Wallet?
  bank_accounts      BankAccount[]
  transactions       Transaction[]
  trades             Trade[]
  payouts            Payout[]
  support_tickets    SupportTicket[]
  support_messages   SupportMessage[]
  notifications      Notification[]
  referrals_made     Referral[]      @relation("ReferrerReferrals")
  referrals_received Referral[]      @relation("ReferredReferrals")
  trades_processed   Trade[]         @relation("ProcessedTrades")

  @@index([phone])
  @@index([referral_code])
}

model KYC {
  id          String    @id @default(cuid())
  user_id     String    @unique
  bvn         String?
  nin         String?
  selfie_url  String?
  id_card_url String?
  status      KycStatus @default(Pending)
  admin_note  String?
  reviewed_at DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Wallet {
  id         String   @id @default(cuid())
  user_id    String   @unique
  balance    Decimal  @default(0) @db.Decimal(20, 2)
  currency   String   @default("NGN")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model BankAccount {
  id             String   @id @default(cuid())
  user_id        String
  bank_name      String
  bank_code      String
  account_number String
  account_name   String
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now())

  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payouts Payout[]

  @@index([user_id])
}

model Transaction {
  id             String          @id @default(cuid())
  user_id        String
  type           TransactionType
  amount         Decimal         @db.Decimal(20, 2)
  balance_before Decimal         @db.Decimal(20, 2)
  balance_after  Decimal         @db.Decimal(20, 2)
  description    String
  reference      String          @unique @default(cuid())
  metadata       Json?
  created_at     DateTime        @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
}

model CardBrand {
  id         String     @id @default(cuid())
  name       String     @unique
  logo_url   String?
  is_active  Boolean    @default(true)
  sort_order Int        @default(0)
  created_at DateTime   @default(now())

  rates  CardRate[]
  trades Trade[]
}

model CardRate {
  id              String   @id @default(cuid())
  card_brand_id   String
  card_type       String
  denomination    String
  rate_per_dollar Decimal  @db.Decimal(10, 2)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  card_brand CardBrand @relation(fields: [card_brand_id], references: [id], onDelete: Cascade)

  @@unique([card_brand_id, card_type, denomination])
  @@index([card_brand_id])
}

model Trade {
  id             String      @id @default(cuid())
  user_id        String
  card_brand_id  String
  card_brand_name String
  card_type      String
  denomination   String
  quantity       Int         @default(1)
  card_image_url String?
  ecode          String?
  naira_amount   Decimal     @db.Decimal(20, 2)
  rate_used      Decimal     @db.Decimal(10, 2)
  status         TradeStatus @default(Pending)
  admin_note     String?
  processed_by   String?
  processed_at   DateTime?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  card_brand CardBrand  @relation(fields: [card_brand_id], references: [id])
  processor  User?      @relation("ProcessedTrades", fields: [processed_by], references: [id])
  payout     Payout?
  tickets    SupportTicket[]

  @@index([user_id])
  @@index([status])
  @@index([created_at])
}

model Payout {
  id                    String       @id @default(cuid())
  user_id               String
  trade_id              String?      @unique
  amount                Decimal      @db.Decimal(20, 2)
  bank_account_id       String
  paystack_reference    String?      @unique
  paystack_transfer_code String?
  status                PayoutStatus @default(Pending)
  failure_reason        String?
  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt

  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bank_account BankAccount @relation(fields: [bank_account_id], references: [id])
  trade        Trade?      @relation(fields: [trade_id], references: [id])

  @@index([user_id])
  @@index([status])
}

model SupportTicket {
  id         String       @id @default(cuid())
  user_id    String
  trade_id   String?
  subject    String
  status     TicketStatus @default(Open)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  user     User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trade    Trade?           @relation(fields: [trade_id], references: [id])
  messages SupportMessage[]

  @@index([user_id])
}

model SupportMessage {
  id             String   @id @default(cuid())
  ticket_id      String
  sender_id      String
  message        String
  attachment_url String?
  created_at     DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
}

model Notification {
  id         String   @id @default(cuid())
  user_id    String
  title      String
  body       String
  type       String
  data       Json?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
}

model Referral {
  id           String   @id @default(cuid())
  referrer_id  String
  referred_id  String   @unique
  bonus_amount Decimal  @db.Decimal(20, 2) @default(1000)
  is_paid      Boolean  @default(false)
  paid_at      DateTime?
  created_at   DateTime @default(now())

  referrer User @relation("ReferrerReferrals", fields: [referrer_id], references: [id], onDelete: Cascade)
  referred User @relation("ReferredReferrals", fields: [referred_id], references: [id], onDelete: Cascade)

  @@index([referrer_id])
}
